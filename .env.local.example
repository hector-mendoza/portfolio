# Resend API Key - Get from https://resend.com/api-keys
RESEND_API_KEY=your_resend_api_key_here

# hCaptcha Keys - Get from https://dashboard.hcaptcha.com/
HCAPTCHA_SECRET_KEY=your_hcaptcha_secret_key_here
NEXT_PUBLIC_HCAPTCHA_SITE_KEY=your_hcaptcha_site_key_here

# Your contact email
CONTACT_EMAIL=hey@hectormendoza.me

# Sanity CMS — create a project at https://www.sanity.io/manage
NEXT_PUBLIC_SANITY_PROJECT_ID=your_sanity_project_id
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2025-01-01

# Optional: read token for draft preview (server-side only)
# SANITY_API_READ_TOKEN=your_sanity_read_token
